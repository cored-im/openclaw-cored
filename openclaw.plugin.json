{
  "id": "cored",
  "kind": "channel",
  "channels": ["cored"],
  "name": "Cored Channel",
  "description": "Connect OpenClaw with Cored",
  "setupEntry": "./dist/setup-entry.js",
  "configSchema": {
    "type": "object",
    "properties": {
      "appId": {
        "type": "string",
        "description": "App ID"
      },
      "appSecret": {
        "type": "string",
        "description": "App Secret"
      },
      "backendUrl": {
        "type": "string",
        "description": "Backend URL"
      },
      "enabled": {
        "type": "boolean",
        "description": "Enable this channel",
        "default": true
      },
      "enableEncryption": {
        "type": "boolean",
        "description": "Enable encryption",
        "default": false
      },
      "requestTimeout": {
        "type": "number",
        "description": "Request timeout in milliseconds",
        "default": 30000
      }
    },
    "required": ["appId", "appSecret", "backendUrl"]
  },
  "uiHints": {
    "appId": { "label": "App ID" },
    "appSecret": { "label": "App Secret", "sensitive": true },
    "backendUrl": { "label": "Backend URL", "placeholder": "https://your-backend-url.com" },
    "enabled": { "label": "Enabled" },
    "enableEncryption": { "label": "Enable Encryption" },
    "requestTimeout": { "label": "Request Timeout (ms)", "placeholder": "30000" }
  }
}
